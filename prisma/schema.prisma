generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "commonjs"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model User {
  id             String   @id @default(uuid()) @db.Uuid
  email          String   @unique @db.VarChar(255)
  password_hash  String   @db.VarChar(255)
  name           String   @db.VarChar(100)
  is_active      Boolean  @default(true)
  email_verified Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @updatedAt @db.Timestamptz

  refresh_tokens RefreshToken[]
  exercises      Exercise[]
  routines       Routine[]
  workouts       Workout[]

  @@index([is_active])
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique @db.VarChar(255)
  expires_at DateTime  @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz
  revoked_at DateTime? @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// EXERCISES & ROUTINES
// ─────────────────────────────────────────────

model Exercise {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  name        String   @db.VarChar(150)
  category    String   @db.VarChar(100)
  type        String   @db.VarChar(50)
  notes       String?  @db.Text
  is_archived Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  user              User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  routine_exercises RoutineExercise[]
  sets              Set[]

  @@index([user_id])
  @@index([user_id, category])
  @@map("exercises")
}

model Routine {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  name        String   @db.VarChar(150)
  description String?  @db.Text
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  user              User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  routine_exercises RoutineExercise[]
  workouts          Workout[]

  @@index([user_id])
  @@map("routines")
}

model RoutineExercise {
  id              String  @id @default(uuid()) @db.Uuid
  routine_id      String  @db.Uuid
  exercise_id     String  @db.Uuid
  target_sets     Int
  target_reps_min Int
  target_reps_max Int
  target_rest_sec Int
  order_index     Int
  notes           String? @db.Text

  routine  Routine  @relation(fields: [routine_id], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exercise_id], references: [id])

  @@unique([routine_id, order_index])
  @@index([routine_id, order_index])
  @@index([exercise_id])
  @@map("routine_exercises")
}

// ─────────────────────────────────────────────
// WORKOUTS & SETS
// ─────────────────────────────────────────────

model Workout {
  id          String    @id @default(uuid()) @db.Uuid
  user_id     String    @db.Uuid
  routine_id  String?   @db.Uuid
  started_at  DateTime  @db.Timestamptz
  finished_at DateTime? @db.Timestamptz
  notes       String?   @db.Text
  created_at  DateTime  @default(now()) @db.Timestamptz

  user    User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  routine Routine? @relation(fields: [routine_id], references: [id], onDelete: SetNull)
  sets    Set[]

  @@index([user_id, started_at(sort: Desc)])
  @@index([routine_id])
  @@map("workouts")
}

model Set {
  id          String   @id @default(uuid()) @db.Uuid
  workout_id  String   @db.Uuid
  exercise_id String   @db.Uuid
  set_number  Int
  weight      Decimal  @db.Decimal(6, 2)
  reps        Int
  rpe         Decimal? @db.Decimal(3, 1)
  is_warmup   Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz

  workout  Workout  @relation(fields: [workout_id], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exercise_id], references: [id])

  @@unique([workout_id, exercise_id, set_number])
  @@index([workout_id, exercise_id, set_number])
  @@index([exercise_id, created_at(sort: Desc)])
  @@map("sets")
}
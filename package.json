		"@types/supertest": "^7.2.0",
		"prisma": "^7.5.0",
		"supertest": "^7.2.2",
		"ts-loader": "^9.5.4",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},

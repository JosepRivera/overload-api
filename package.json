		"@nestjs/swagger": "^11.2.6",
		"@prisma/adapter-pg": "^7.5.0",
		"@prisma/client": "^7.5.0",
		"bcrypt": "^6.0.0",
		"helmet": "^8.1.0",
		"jose": "^6.2.1",
		"ms": "^2.1.3",
		"nestjs-zod": "^5.1.1",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@nestjs/cli": "^11.0.16",
		"@nestjs/schematics": "^11.0.9",

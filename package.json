{
	"name": "overload-api",
	"version": "0.0.1",
	"description": "",
	"author": "JosepRivera",
	"private": true,
	"license": "MIT",
	"scripts": {
		"start:dev": "nest start --watch",
		"build": "nest build",
		"lint": "biome check --write ./src ./test",
		"dev": "docker compose up",
		"dev:build": "docker compose up --build",
		"stop": "docker compose down",
		"db:migrate": "docker exec -it overload-app-dev pnpm prisma migrate dev",
		"db:gen": "docker exec overload-app-dev pnpm prisma generate",
		"db:seed": "docker exec overload-app-dev pnpm tsx prisma/seed.ts",
		"db:reset": "docker exec -it overload-app-dev pnpm prisma migrate reset",
		"shell": "docker exec -it overload-app-dev sh",
		"clean": "docker compose down -v",
		"test": "vitest run --project unit",
		"test:e2e": "docker compose -f docker-compose.test.yml up --build --abort-on-container-exit --exit-code-from app-test --remove-orphans",
		"test:e2e:down": "docker compose -f docker-compose.test.yml down -v"
	},
	"dependencies": {
		"@nestjs/common": "^11.1.18",
		"@nestjs/config": "^4.0.3",
		"@nestjs/core": "^11.1.18",
		"@nestjs/platform-express": "^11.1.18",
		"@nestjs/swagger": "^11.2.6",
		"@prisma/adapter-pg": "^7.6.0",
		"@prisma/client": "^7.6.0",
		"bcrypt": "^6.0.0",
		"dotenv": "^17.4.0",
		"helmet": "^8.1.0",
		"jose": "^6.2.2",
		"ms": "^2.1.3",
		"nestjs-zod": "^5.2.1",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@nestjs/cli": "^11.0.17",
		"@nestjs/schematics": "^11.0.10",
		"@nestjs/testing": "^11.1.18",
		"@swc/core": "^1.15.21",
		"@swc/helpers": "^0.5.21",
		"@tsconfig/node24": "^24.0.4",
		"@types/bcrypt": "^6.0.0",
		"@types/express": "^5.0.6",
		"@types/ms": "^2.1.0",
		"@types/node": "^24.12.2",
		"@types/supertest": "^7.2.0",
		"@vitest/coverage-v8": "^4.1.2",
		"prisma": "^7.6.0",
		"supertest": "^7.2.2",
		"ts-loader": "^9.5.7",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"unplugin-swc": "^1.5.9",
		"vitest": "^4.1.2"
	},
	"packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268"
}

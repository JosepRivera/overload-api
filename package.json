{
	"name": "overload-api",
	"version": "0.0.1",
	"description": "",
	"author": "JosepRivera",
	"private": true,
	"license": "MIT",
	"scripts": {
		"start:dev": "nest start --watch",
		"build": "nest build",
		"lint": "biome check --write ./src",
		"dev": "docker compose up",
		"dev:build": "docker compose up --build",
		"stop": "docker compose down",
		"db:migrate": "docker exec -it overload-app-dev pnpm prisma migrate dev",
		"db:gen": "docker exec overload-app-dev pnpm prisma generate",
		"db:seed": "docker exec overload-app-dev pnpm tsx prisma/seed.ts",
		"db:reset": "docker exec -it overload-app-dev pnpm prisma migrate reset",
		"shell": "docker exec -it overload-app-dev sh",
		"clean": "docker compose down -v"
	},
	"dependencies": {
		"@nestjs/common": "^11.1.16",
		"@nestjs/config": "^4.0.3",
		"@nestjs/core": "^11.1.16",
